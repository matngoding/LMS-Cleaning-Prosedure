[\n    {\n        "task": "Cleaning Toilet",\n        "instructions": [\n            "Gather all necessary cleaning supplies such as toilet brush, disinfectant, and gloves.",\n            "Put on gloves before starting the cleaning process.",\n            "Apply disinfectant inside the toilet bowl and let it sit for a few minutes.",\n            "Scrub the toilet bowl with the brush, focusing on the rim and under the seat.",\n            "Flush the toilet to rinse away the cleaning solution.",\n            "Wipe down the outer surfaces of the toilet with disinfectant wipes.\n        ]\n    },\n    {\n        "task": "Cleaning Kitchen",\n        "instructions": [\n            "Clear off the countertops and remove any items that do not belong there.",\n            "Wash all dishes and clean the sink with disinfectant.",\n            "Wipe down the countertops with a multi-surface cleaner.",\n            "Clean the stove top and oven with appropriate cleaning solution.",\n            "Sweep and mop the kitchen floor to remove any debris.\n        ]\n    },\n    {\n        "task": "Cleaning Floors",\n        "instructions": [\n            "Sweep or vacuum the floors to remove dust and debris.",\n            "Prepare a mop bucket with warm water and a suitable floor cleaner.",\n            "Mop the floors in sections, rinsing the mop frequently as needed.",\n            "Allow the floor to dry completely before returning furniture to its original place.\n        ]\n    },\n    {\n        "task": "Cleaning Windows",\n        "instructions": [\n            "Gather window cleaning solution and microfiber cloths.",\n            "Spray the cleaning solution on the window surface from top to bottom.",\n            "Use a microfiber cloth to wipe the window in a circular motion.",\n            "For hard-to-reach areas, use a squeegee.\n        ]\n    },\n    {\n        "task": "Cleaning Common Areas",\n        "instructions": [\n            "Pick up any litter or items that do not belong in the area.",\n            "Wipe down surfaces with disinfectant wipes or spray.",\n            "Vacuum or sweep the floor as needed and mop if necessary.\n        ]\n    },\n    {\n        "task": "Trash Management",\n        "instructions": [\n            "Check all bins and empty them into the main trash bag.",\n            "Replace liners in each bin before returning them to their place.",\n            "Dispose of the trash in the designated area outside.\n        ]\n    },\n    {\n        "task": "Equipment Maintenance",\n        "instructions": [\n            "Check all cleaning equipment for any damage or wear and tear.",\n            "Clean equipment after each use to ensure longevity.",\n            "Store equipment in a designated area to prevent damage.\n        ]\n    }\n]